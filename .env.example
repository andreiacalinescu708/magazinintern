# Configurare Bază de Date
DATABASE_URL=postgresql://username:password@localhost:5432/openbill

# Configurare Email (SendGrid)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=your_sendgrid_api_key
EMAIL_FROM=support@openbill.ro

# Configurare Telegram Bot
# 1. Creează un bot nou în Telegram folosind @BotFather
# 2. Copiază token-ul aici
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Configurare criptare token SmartBill (opțional)
TOKEN_ENCRYPTION_KEY=your-32-char-encryption-key-here!!

# Configurare sesiuni
SESSION_SECRET=your-session-secret-here

# Port server
PORT=3000
